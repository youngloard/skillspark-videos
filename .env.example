# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Production runs on PostgreSQL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
# Public origin of the deployed site (used for OAuth callbacks).
AUTH_URL="https://videos.skillspark.study"
# Required when running behind a proxy/host (Railway, Vercel, etc.).
AUTH_TRUST_HOST="true"

# Google OAuth (Google Cloud Console -> OAuth 2.0 Client IDs)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Bootstrap admin email (used by seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="Root Admin"

# --------------------------------------------------------------------------
# Google Drive — pick ONE of the two options below.
# --------------------------------------------------------------------------
#
# Option A (RECOMMENDED): Service account
#   Works for files shared as "anyone with link" AND for files restricted to
#   specific people. The admin shares each Drive file (or the parent folder)
#   with the service-account email and the server reads them on behalf of the
#   service account. Students never need direct Drive access.
#
#   Setup:
#     1. Google Cloud Console -> IAM & Admin -> Service Accounts -> Create
#     2. Open the new service account -> Keys -> Add key -> JSON. Download.
#     3. Enable the Drive API for your project (APIs & Services -> Library).
#     4. Open the downloaded JSON, paste it as a single line below. The
#        `\n` escapes inside `private_key` will be parsed correctly.
#     5. In Drive, right-click the video folder/file -> Share. Share with the
#        `client_email` from the JSON (e.g. xxx@yyy.iam.gserviceaccount.com)
#        with "Viewer" access.
GOOGLE_SERVICE_ACCOUNT_JSON=""

# Option B (FALLBACK): Public-link API key
#   Only works for files shared as "anyone with link". If set together with
#   GOOGLE_SERVICE_ACCOUNT_JSON, the service account takes precedence.
#   Cloud Console -> APIs & Services -> Credentials -> API key.
GOOGLE_DRIVE_API_KEY=""

# --------------------------------------------------------------------------
# Gemini AI assistant (admin chatbot + student help widget)
# --------------------------------------------------------------------------
# Google AI Studio -> Get API key (https://aistudio.google.com/app/apikey).
# Used by the admin AI assistant (function-calling for CRUD) and the student
# floating chat (Q&A only). Leave blank to disable the chat features.
GOOGLE_GEMINI_API_KEY=""
# Optional override; defaults to "gemini-2.0-flash" — a fast, function-calling-
# capable model. You can pin a newer model (e.g. gemini-2.5-flash) without
# code changes.
GEMINI_MODEL=""

# --------------------------------------------------------------------------
# Email — admin -> student notifications (e.g. "how to access" mails)
# --------------------------------------------------------------------------
#
# PREFERRED on Railway/PaaS: ZeptoMail HTTP API (Zoho's transactional email).
# SMTP ports are firewalled on Railway, so SMTP will NOT work there — use this.
#   1. ZeptoMail (zoho.com/zeptomail) -> add a Mail Agent -> verify your domain
#      (adds SPF/DKIM DNS records).
#   2. Mail Agent -> "Send Mail" token. Paste it below (just the token; the app
#      prepends "Zoho-enczapikey ").
#   3. EMAIL_FROM_ADDRESS must be an address on the verified domain.
ZEPTOMAIL_TOKEN=""
# India DC by default; use api.zeptomail.com for US, api.zeptomail.eu for EU.
ZEPTOMAIL_API_URL="https://api.zeptomail.in/v1.1/email"
# Verified sender address (defaults to EMAIL_SMTP_USER if blank).
EMAIL_FROM_ADDRESS=""
#
# FALLBACK (local/dev only, where SMTP isn't blocked): Zoho Mail SMTP.
# Example uses Zoho Mail. Host depends on your data center:
#   India: smtp.zoho.in | US: smtp.zoho.com | EU: smtp.zoho.eu | AU: smtp.zoho.com.au
# Enable IMAP/SMTP for the mailbox and generate an APP-SPECIFIC password
# (Zoho -> My Account -> Security -> App Passwords). Leave blank to disable email.
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="465"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASS=""
# Display name on outgoing mail; falls back to EMAIL_SMTP_USER.
EMAIL_FROM_NAME="SkillSpark Academic Coordinator"
# Reply-To address; falls back to EMAIL_SMTP_USER.
EMAIL_REPLY_TO=""
# Platform URL inserted via the {{platformUrl}} placeholder in templates.
EMAIL_PLATFORM_URL="https://videos.skillspark.study"
#
# DELIVERABILITY (do this or bulk mail lands in spam):
#   In your DNS for the sending domain, add the records your mail host gives you:
#     - SPF   (TXT): authorizes the host to send for the domain
#     - DKIM  (TXT): cryptographic signature; enable DKIM in the mail admin console
#     - DMARC (TXT): e.g. "v=DMARC1; p=quarantine; rua=mailto:postmaster@yourdomain"
#   The From address MUST be on the same domain that SPF/DKIM cover (it is:
#   EMAIL_SMTP_USER's domain). The app already sends one private copy per student
#   with Reply-To + List-Unsubscribe headers and a send throttle.
